{
  "name": "askai",
  "version": "0.1.0",
  "description": "A terminal AI agent that answers your questions",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "askai": "src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "build": "bun build ./src/index.ts --compile --outfile askai",
    "dev": "bun --watch src/index.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.9",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@opentui/core": "^0.1.92",
    "commander": "^12.1.0",
    "inquirer": "^9.3.8",
    "openai": "^4.104.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/inquirer": "^9.0.9"
  },
  "optionalDependencies": {
    "@opentui/core-darwin-arm64": "^0.1.92",
    "@opentui/core-darwin-x64": "^0.1.92",
    "@opentui/core-linux-arm64": "^0.1.92",
    "@opentui/core-linux-x64": "^0.1.92"
  }
}
