{
  "name": "askai",
  "version": "0.1.0",
  "description": "A terminal AI agent that answers your questions",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "askai": "src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "build": "bun build ./src/index.ts --compile --outfile askai",
    "dev": "bun --watch src/index.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@opentui/core": "^0.1.91",
    "commander": "^12.0.0",
    "inquirer": "^9.2.0",
    "openai": "^4.40.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/inquirer": "^9.0.0"
  }
}
